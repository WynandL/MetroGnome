    <path android:strokeColor="#FFD700" android:strokeWidth="1.2" android:fillColor="#00000000"
        android:pathData="M 64.5,38 L 67,39"/>

    <!-- Lens reflections -->
    <path android:strokeColor="#4466AA" android:strokeWidth="1.5" android:strokeAlpha="0.5"
        android:fillColor="#00000000" android:strokeLineCap="round"
        android:pathData="M 45.5,36.5 L 47,38.5"/>
