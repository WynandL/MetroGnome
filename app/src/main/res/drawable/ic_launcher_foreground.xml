            android:pathData="M 50,13 L 51.4,16.8 L 55.4,16.8 L 52.3,19.1 L 53.5,23 L 50,20.8 L 46.5,23 L 47.7,19.1 L 44.6,16.8 L 48.6,16.8 Z"/>

