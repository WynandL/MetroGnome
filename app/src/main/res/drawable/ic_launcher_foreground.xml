        <path android:fillColor="#881010"
            android:pathData="M 54,28 m -17,0 a 17,3 0 1,0 34,0 a 17,3 0 1,0 -34,0"/>

        <!-- Cone body (gradient approx: light → main → dark from tip to base) -->
        <path android:fillColor="#CC1818"
            android:pathData="M 54,4 C 52,8 45,16 41,22 C 38,26 37,28 37,29 L 71,29 C 71,28 70,26 67,22 C 63,16 56,8 54,4 Z"/>

        <!-- Left-side shading -->
