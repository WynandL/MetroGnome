    <!-- ===================== HAT — red cone, 11° tilt, gold star ===================== -->
    <!--
      Hat drawn flat then the whole group uses a rotation transform.
      Pivot = hat base centre (54, 29) for the 11° tilt.
    -->
    <group
        android:pivotX="54"
        android:pivotY="29"
        android:rotation="11">

        <!-- Brim shadow -->
        <path android:fillColor="#6A0A0A" android:fillAlpha="0.75"
            android:pathData="M 54,29 m -18,0 a 18,3.5 0 1,0 36,0 a 18,3.5 0 1,0 -36,0"/>

