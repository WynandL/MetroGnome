<?xml version="1.0" encoding="utf-8"?>
<!--
  Redirects @drawable/ic_launcher_foreground to the bitmap WebP files
  generated by generate_icon.py.  Both @drawable/ and @mipmap/ references
  now resolve to the same correct Metro image.
-->
<bitmap xmlns:android="http://schemas.android.com/apk/res/android"
    android:src="@mipmap/ic_launcher_foreground" />
