<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive icon for API 26+.
  Foreground: ic_launcher_foreground.webp generated by generate_icon.py
              (Metro the gnome on transparent background, padded to the 72/108dp safe zone)
  Background: dark forest-green gradient defined in ic_launcher_background.xml
-->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <background android:drawable="@drawable/ic_launcher_background" />
    <foreground android:drawable="@mipmap/ic_launcher_foreground" />
</adaptive-icon>
